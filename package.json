{
	"name": "tanstack-fullstack-template",
	"private": true,
	"type": "module",
	"version": "0.1.0",
	"scripts": {
		"dev": "NODE_OPTIONS='--import ./instrument.server.mjs' vite dev --port 3000",
		"build": "vite build && cp instrument.server.mjs .output/server",
		"start": "node --import ./.output/server/instrument.server.mjs .output/server/index.mjs",
		"preview": "vite preview",
		"test": "vitest run",
		"test:skills": "vitest run scripts/skills/buildSkills.test.ts",
		"test:e2e": "playwright test",
		"format": "biome check --write --unsafe",
		"lint": "biome check && pnpm typecheck && pnpm skills:check",
		"typecheck": "tsc --noEmit",
		"skills:build": "node ./scripts/skills/buildSkills.mjs",
		"skills:check": "node ./scripts/skills/buildSkills.mjs --check"
	},
	"dependencies": {
		"@mantine/core": "^8.3.18",
		"@mantine/hooks": "^8.3.18",
		"@mantine/notifications": "^8.3.18",
		"@sentry/tanstackstart-react": "^10.48.0",
		"@tanstack/ai": "^0.5.1",
		"@tanstack/ai-client": "^0.4.5",
		"@tanstack/ai-gemini": "0.5.0",
		"@tanstack/ai-openai": "^0.5.0",
		"@tanstack/ai-react": "^0.5.4",
		"@tanstack/react-devtools": "^0.7.11",
		"@tanstack/react-router": "^1.168.15",
		"@tanstack/react-router-devtools": "^1.166.13",
		"@tanstack/react-start": "^1.167.28",
		"@tanstack/router-plugin": "^1.167.14",
		"jose": "^6.2.2",
		"lucide-react": "^0.561.0",
		"mongodb": "^7.1.1",
		"nitro": "npm:nitro-nightly@3.0.1-20260124-124125-d6734a17",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-markdown": "^10.1.0",
		"remark-gfm": "^4.0.1",
		"vite-tsconfig-paths": "^6.1.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.4",
		"@netlify/vite-plugin-tanstack-start": "^1.3.3",
		"@playwright/test": "^1.59.1",
		"@tanstack/devtools-vite": "^0.3.12",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^22.19.17",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react-swc": "^4.3.0",
		"ajv": "^8.18.0",
		"jsdom": "^27.4.0",
		"playwright": "^1.59.1",
		"typescript": "^5.9.3",
		"vite": "^7.3.2",
		"vitest": "^3.2.4",
		"yaml": "^2.8.3"
	}
}
