{
	"name": "tanstack-fullstack-template",
	"private": true,
	"type": "module",
	"version": "0.1.0",
	"scripts": {
		"dev": "NODE_OPTIONS='--import ./instrument.server.mjs' vite dev --port 3000",
		"build": "vite build && cp instrument.server.mjs .output/server",
		"start": "node --import ./.output/server/instrument.server.mjs .output/server/index.mjs",
		"preview": "vite preview",
		"test": "vitest run",
		"test:skills": "vitest run scripts/skills/buildSkills.test.ts",
		"test:e2e": "playwright test",
		"format": "biome check --write --unsafe",
		"lint": "biome check && pnpm typecheck && pnpm skills:check",
		"typecheck": "tsc --noEmit",
		"skills:build": "node ./scripts/skills/buildSkills.mjs",
		"skills:check": "node ./scripts/skills/buildSkills.mjs --check"
	},
	"dependencies": {
		"@mantine/core": "^9.0.1",
		"@mantine/hooks": "^9.0.1",
		"@mantine/notifications": "^9.0.1",
		"@sentry/tanstackstart-react": "^10.48.0",
		"@tanstack/ai": "^0.10.2",
		"@tanstack/ai-client": "^0.7.9",
		"@tanstack/ai-gemini": "^0.8.6",
		"@tanstack/ai-openai": "^0.7.4",
		"@tanstack/ai-react": "^0.7.10",
		"@tanstack/react-devtools": "^0.10.2",
		"@tanstack/react-router": "^1.168.18",
		"@tanstack/react-router-devtools": "^1.166.13",
		"@tanstack/react-start": "^1.167.32",
		"jose": "^6.2.2",
		"lucide-react": "^1.8.0",
		"mongodb": "^7.1.1",
		"nitro": "npm:nitro-nightly@3.0.1-20260410-164248-8ab58a4b",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-markdown": "^10.1.0",
		"remark-gfm": "^4.0.1",
		"vite-tsconfig-paths": "^6.1.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.11",
		"@netlify/vite-plugin-tanstack-start": "^1.3.3",
		"@playwright/test": "^1.59.1",
		"@tanstack/devtools-vite": "^0.6.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react-swc": "^4.3.0",
		"ajv": "^8.18.0",
		"jsdom": "^29.0.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.8",
		"vitest": "^4.1.4",
		"yaml": "^2.8.3"
	}
}
