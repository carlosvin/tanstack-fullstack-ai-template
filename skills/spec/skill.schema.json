{
	"$schema": "https://json-schema.org/draft/2020-12/schema",
	"$id": "https://raw.githubusercontent.com/carlosvin/tanstack-fullstack-ai-template/main/skills/spec/skill.schema.json",
	"title": "CanonicalSkill",
	"type": "object",
	"additionalProperties": false,
	"required": [
		"id",
		"title",
		"summary",
		"projectName",
		"projectSummary",
		"version",
		"author",
		"license",
		"homepage",
		"repository",
		"documentationUrl",
		"status",
		"supportedTools",
		"tags",
		"capabilities",
		"triggers",
		"inputs",
		"outputs",
		"constraints",
		"steps",
		"examples",
		"content"
	],
	"properties": {
		"id": {
			"type": "string",
			"pattern": "^[a-z0-9-]+$",
			"minLength": 3
		},
		"title": {
			"type": "string",
			"minLength": 3
		},
		"summary": {
			"type": "string",
			"minLength": 10
		},
		"projectName": {
			"type": "string",
			"minLength": 3
		},
		"projectSummary": {
			"type": "string",
			"minLength": 10
		},
		"version": {
			"type": "string",
			"pattern": "^\\d+\\.\\d+\\.\\d+$"
		},
		"author": {
			"type": "object",
			"additionalProperties": false,
			"required": ["name"],
			"properties": {
				"name": {
					"type": "string",
					"minLength": 2
				},
				"url": {
					"type": "string",
					"pattern": "^https?://.+$"
				}
			}
		},
		"license": {
			"type": "string",
			"minLength": 2
		},
		"homepage": {
			"type": "string",
			"pattern": "^https?://.+$"
		},
		"repository": {
			"type": "string",
			"pattern": "^https?://.+$"
		},
		"documentationUrl": {
			"type": "string",
			"pattern": "^https?://.+$"
		},
		"status": {
			"type": "string",
			"enum": ["stable", "beta", "experimental", "deprecated"]
		},
		"supportedTools": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "object",
				"additionalProperties": false,
				"required": ["id", "name", "installMode", "tested"],
				"properties": {
					"id": {
						"type": "string",
						"pattern": "^[a-z0-9-]+$",
						"minLength": 2
					},
					"name": {
						"type": "string",
						"minLength": 2
					},
					"installMode": {
						"type": "string",
						"enum": ["native", "copy"]
					},
					"tested": {
						"type": "boolean"
					},
					"notes": {
						"type": "string",
						"minLength": 1
					}
				}
			}
		},
		"tags": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "string",
				"minLength": 2
			}
		},
		"capabilities": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "string",
				"minLength": 2
			}
		},
		"triggers": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "string",
				"minLength": 2
			}
		},
		"inputs": {
			"type": "array",
			"items": {
				"type": "string",
				"minLength": 1
			}
		},
		"outputs": {
			"type": "array",
			"items": {
				"type": "string",
				"minLength": 1
			}
		},
		"constraints": {
			"type": "array",
			"items": {
				"type": "string",
				"minLength": 1
			}
		},
		"steps": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "string",
				"minLength": 1
			}
		},
		"examples": {
			"type": "array",
			"minItems": 1,
			"items": {
				"type": "object",
				"additionalProperties": false,
				"required": ["input", "output"],
				"properties": {
					"input": {
						"type": "string",
						"minLength": 1
					},
					"output": {
						"type": "string",
						"minLength": 1
					}
				}
			}
		},
		"content": {
			"type": "string",
			"minLength": 20
		}
	}
}
